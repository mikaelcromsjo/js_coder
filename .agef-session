{
  "string_app_name": "quis",
  "string_original_requirement": "create a fun quis gave that is a word game, the answer is not what you expect but rather a joke",
  "string_formal_spec": "FUNCTIONS:\nget_str_joke() - returns a joke as a string\nget_str_word() - returns a random word as a string\nrun_game() - starts the word game with a side effect\nsave_str_joke_to_db() - persists a joke to a database\nset_bool_game_over() - mutates the game over state variable\ntry_get_str_joke_from_api() - async operation to fetch a joke from an API\nlog_str_error() - writes an error message to the console\nget_dict_word_joke_map() - returns a dictionary mapping words to jokes\nset_dict_word_joke_map() - mutates the word joke map state variable\nget_bool_game_over() - returns the game over state as a boolean\nrun_check_answer() - checks the user's answer with a side effect\nget_str_user_answer() - returns the user's answer as a string\nset_str_user_answer() - mutates the user's answer state variable\n\nCONSTRAINTS:\n- All functions must be exported\n- No mutable state outside of state.js\n- All async operations must use try/catch\n- No empty catch blocks\n- No unused imports\n- No duplicate functions with different signatures\n- Function names must follow the verb + returnType + concept format\n- Input types must be specified in parameter names only\n- No nesting of functions\n- No classes or this keyword\n- All errors must be logged before being thrown",
  "int_last_passing_revision": 3
}